# ─── Google OAuth (NextAuth) ──────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Add authorized redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── NextAuth ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# ─── Google Calendar ──────────────────────────────────────────
# The ID of your shared family calendar.
# Find it in Google Calendar → Settings → your calendar → Calendar ID
# It looks like: abc123xyz@group.calendar.google.com
# Use "primary" to use the main calendar of the signed-in account.
GOOGLE_CALENDAR_ID=primary

# ─── Authorized Admin Emails ──────────────────────────────────
# Comma-separated list of Google email addresses that can access
# the admin page and meeting page. Everyone else gets a 403.
ADMIN_EMAILS=your.email@gmail.com,another.admin@gmail.com

# ─── Twilio (added later) ─────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ─── Google Sheets (added later) ──────────────────────────────
# GOOGLE_SHEETS_ID=
