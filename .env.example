# ─── Google OAuth (NextAuth) ──────────────────────────────────
# Create at: https://console.cloud.google.com -> APIs & Services -> Credentials
# Add authorized redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── NextAuth ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Internal/Cron Auth ───────────────────────────────────────
# Generate with: openssl rand -base64 32
CRON_SECRET=your_internal_cron_secret

# ─── Google Calendar ──────────────────────────────────────────
# The ID of your shared family calendar.
# Find it in Google Calendar -> Settings -> your calendar -> Calendar ID
# It looks like: abc123xyz@group.calendar.google.com
# Use "primary" to use the main calendar of the signed-in account.
GOOGLE_CALENDAR_ID=primary

# ─── Authorized Admin Emails ──────────────────────────────────
# Comma-separated list of Google email addresses that can access
# Google OAuth-backed Sunday planning. If empty, Google sign-in is denied.
ADMIN_EMAILS=your.email@gmail.com,another.admin@gmail.com

# ─── Google Service Account ───────────────────────────────────
# JSON service account key for dashboard calendar reads.
# Share the Google Calendar with the service account email.
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ─── Twilio ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
